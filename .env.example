# FrequencyManager — environment variables
#
# None of these are required to run the app — every one has a sensible
# default baked into core/kernel.ts / src/main.ts. Copy this file to `.env`
# (already gitignored) if you want to override any of them locally; the app
# does not currently read secrets from an .env file at all.

# Standard Node environment. Controls hot-reload defaults and a couple of
# main-process dev-only branches (e.g. opening DevTools automatically).
# Values: development | production | test
NODE_ENV=development

# Minimum log level emitted by the kernel's StructuredLogger.
# Values: debug | info | warn | error
LOG_LEVEL=info

# Overrides where the kernel looks for config/default.json (and
# config/<NODE_ENV>.json). Useful when running a packaged build against a
# config directory outside the install location. Normally left unset — the
# kernel already falls back through packaged extraResources → repo root →
# cwd, see core/kernel.ts's `loadConfiguration()`.
# FM_CONFIG_DIR=

# Comma-separated list of directories to scan for feature modules.
# Only read by the legacy src/main.ts bootstrapper; the real Electron
# entrypoint (src/main/electron-main.ts) reads modulePaths from config/*.json
# instead.
# FREQUENCY_MANAGER_MODULE_PATHS=./modules

# FREQUENCY_MANAGER_HOT_RELOAD=false
# FREQUENCY_MANAGER_LOG_LEVEL=info
