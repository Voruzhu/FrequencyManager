{
    "name": "frequency-manager",
    "version": "1.0.14",
    "description": "Damage calculator, gear optimizer, and OCR scanner for gacha-RPGs - Wuthering Waves and Genshin Impact download separately as game modules",
    "main": "dist/src/main/electron-main.js",
    "scripts": {
        "dev": "electron .",
        "start": "electron .",
        "build:renderer": "vite build --config src/renderer/vite.config.ts",
        "build:main": "tsc && tsc-alias && node scripts/copy-manifests.js",
        "build": "npm run build:renderer && npm run build:main && electron-builder --win nsis --publish never",
        "build:dev": "npm run build:renderer && npm run build:main && electron-builder --dir",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
        "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
        "typecheck:src": "tsc --noEmit",
        "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
        "clean": "rimraf dist",
        "package:games": "node scripts/build-game-package.js"
    },
    "keywords": [
        "wuthering-waves",
        "echo-manager",
        "ocr",
        "damage-calculator",
        "electron",
        "react",
        "typescript"
    ],
    "author": "FrequencyManager Team",
    "license": "MIT",
    "dependencies": {
        "@fontsource/ibm-plex-mono": "^5.2.7",
        "@fontsource/ibm-plex-sans": "^5.2.8",
        "@radix-ui/react-avatar": "^1.2.2",
        "@radix-ui/react-collapsible": "^1.1.16",
        "@radix-ui/react-dialog": "^1.1.19",
        "@radix-ui/react-dropdown-menu": "^2.1.20",
        "@radix-ui/react-label": "^2.1.11",
        "@radix-ui/react-scroll-area": "^1.2.14",
        "@radix-ui/react-select": "^2.3.3",
        "@radix-ui/react-separator": "^1.1.11",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-switch": "^1.3.3",
        "@radix-ui/react-tabs": "^1.1.17",
        "@radix-ui/react-tooltip": "^1.2.12",
        "adm-zip": "^0.6.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "electron-log": "^5.1.0",
        "electron-store": "^8.1.0",
        "electron-updater": "^6.1.7",
        "eventemitter3": "^5.0.1",
        "lucide-react": "^1.23.0",
        "mathjs": "^12.4.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-resizable-panels": "^2.1.9",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tesseract.js": "^5.0.0",
        "winston": "^3.11.0",
        "yaml": "^2.3.4",
        "zod": "^3.22.4",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.5.8",
        "@types/jest": "^29.5.0",
        "@types/node": "^20.10.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "@eslint/js": "^10.0.1",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.5.2",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.0",
        "eslint": "^10.7.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.7.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "postcss": "^8.5.16",
        "prettier": "^3.1.0",
        "rimraf": "^5.0.5",
        "tailwindcss": "^3.4.19",
        "tailwindcss-animate": "^1.0.7",
        "ts-jest": "^29.1.0",
        "tsc-alias": "^1.8.17",
        "typescript": "^5.3.0",
        "vite": "^5.4.21"
    },
    "build": {
        "appId": "com.frequencymanager.app",
        "productName": "FrequencyManager",
        "directories": {
            "output": "dist/installer"
        },
        "files": [
            "dist/**/*",
            "!dist/adapters/game-definitions/wuthering-waves/**",
            "!dist/adapters/game-definitions/genshin-impact/**",
            "!dist/game-packages/**",
            "!dist/installer/**",
            "node_modules/**/*",
            "package.json",
            "config/**/*"
        ],
        "extraResources": [
            {
                "from": "config",
                "to": "config"
            },
            {
                "from": "eng.traineddata",
                "to": "eng.traineddata"
            }
        ],
        "win": {
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "deleteAppDataOnUninstall": true
        },
        "publish": {
            "provider": "github",
            "owner": "Voruzhu",
            "repo": "FrequencyManager"
        }
    }
}
