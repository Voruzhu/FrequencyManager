{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": true,
        "types": [
            "node",
            "jest"
        ]
    },
    "include": [
        "src/**/*",
        "core/**/*",
        "modules/**/*",
        "modules/**/tests/**/*",
        "shared/**/*",
        "adapters/**/*",
        "games/**/*",
        "config/**/*",
        "scripts/**/*",
        "tests/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "*.config.js",
        "*.config.ts"
    ]
}